APP_NAME=HMRPL
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# === DATABASE (ISI DARI HPANEL HOSTINGER) ===
DB_CONNECTION=mysql
DB_HOST=YOUR_DB_HOST
DB_PORT=3306
DB_DATABASE=YOUR_DB_NAME
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASS

# === SESSION & SANCTUM (1 domain) ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=your-domain.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Jika frontend & backend 1 domain:
SANCTUM_STATEFUL_DOMAINS=your-domain.com
# Jika pakai subdomain (mis: app.your-domain.com), pakai:
# SESSION_DOMAIN=.your-domain.com
# SANCTUM_STATEFUL_DOMAINS=app.your-domain.com

# === STORAGE/FILES ===
FILESYSTEM_DISK=public

# === QUEUE/CACHE (aman di shared hosting) ===
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# === REDIS (opsional; biarkan default kalau tak dipakai) ===
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === MAIL (isi SMTP Hostinger kalau mau kirim email) ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=YOUR_SMTP_USER
MAIL_PASSWORD=YOUR_SMTP_PASS
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# === FRONTEND (kalau perlu dipakai di app) ===
VITE_APP_NAME="${APP_NAME}"
FRONTEND_URL=https://your-domain.com
